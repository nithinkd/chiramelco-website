---
import MainLayout from '../layouts/MainLayout.astro';
import { sitePath } from '../utils/sitePath';

interface Detail {
  title: string;
  subtitle: string;
  description: string;
}

interface Props {
  title: string;
  tagline: string;
  intro: string;
  contactIntro: string;
  details: Detail[];
}

const { title, tagline, intro, contactIntro, details } = Astro.props;
---

<MainLayout title={`${title} - Chiramel & Co`}>
  <section class="relative h-[42vh] md:h-[38vh] flex items-center overflow-hidden bg-black">
    <img
      src={sitePath('/images/ipheader.png')}
      alt={`${title} Practice`}
      class="absolute inset-0 w-full h-full object-cover"
    >
    <div class="absolute inset-0 bg-black/60"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
      <p class="text-sm uppercase tracking-[0.28em] text-amber-300 mb-5">Intellectual Property Practice</p>
      <h1 class="text-5xl md:text-6xl font-serif text-white">{title}</h1>
      <p class="mt-4 text-xl md:text-2xl text-amber-300 font-light">{tagline}</p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-6 py-20">
    <div class="max-w-3xl mx-auto text-center mb-20">
      <p class="text-xl leading-relaxed">{intro}</p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 mb-20 max-w-6xl mx-auto">
      {details.map((detail, index) => (
        <section class={`detail-card ${index === details.length - 1 && details.length % 2 === 1 ? 'md:col-span-2' : ''}`}>
          <p class="detail-label">{detail.subtitle}</p>
          <h2 class="text-2xl font-semibold mt-4">{detail.title}</h2>
          <div class="detail-rule" aria-hidden="true"></div>
          <p class="leading-relaxed text-zinc-600 dark:text-zinc-400">{detail.description}</p>
        </section>
      ))}
    </div>

    <div class="text-center mb-16">
      <a href={sitePath('/intellectual-property')} class="back-link">
        <span aria-hidden="true">←</span> Back to IP Practice
      </a>
    </div>

    <section class="ip-contact-card">
      <p class="ip-contact-label">Intellectual Property Practice Contact</p>
      <h2 class="font-serif text-4xl mt-4">IP Desk</h2>
      <p class="mt-5 max-w-xl text-lg leading-relaxed text-zinc-700 dark:text-zinc-300">{contactIntro}</p>

      <div class="grid md:grid-cols-3 gap-8 mt-10 pt-9 border-t border-amber-200 dark:border-amber-900/70">
        <address class="not-italic leading-relaxed text-zinc-600 dark:text-zinc-400">
          <span class="ip-contact-label block mb-4">Office</span>
          C-478, FF, Defence Colony<br>
          New Delhi 110 024, India
        </address>

        <div>
          <p class="ip-contact-label mb-4">Contact</p>
          <a class="ip-contact-link text-xl" href="tel:+919810928556">+91 98109 28556</a>
          <div class="mt-4 space-y-2">
            <a class="ip-contact-link" href="mailto:mail@chiramelco.com">mail@chiramelco.com</a>
            <a class="ip-contact-link" href="mailto:christine@chiramelco.com">christine@chiramelco.com</a>
          </div>
        </div>

        <div class="md:text-center">
          <p class="ip-contact-label mb-4">WhatsApp</p>
          <a href="https://wa.me/919810928556" target="_blank" rel="noopener noreferrer" class="ip-whatsapp">
            <img src={sitePath('/images/whatsapp-christine.svg')} alt="WhatsApp QR code for the IP Desk">
            <span>Scan to connect</span>
          </a>
        </div>
      </div>
    </section>
  </div>
</MainLayout>

<style>
  .detail-card {
    padding: clamp(1.8rem, 4vw, 2.5rem);
    border: 1px solid rgb(228 228 231);
    border-radius: 1.5rem;
    background: white;
  }

  .detail-label,
  .ip-contact-label {
    color: rgb(217 119 6);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .detail-rule {
    width: 2.5rem;
    height: 1px;
    margin: 1.25rem 0 1.5rem;
    background: rgb(217 119 6);
  }

  .ip-contact-card {
    max-width: 62rem;
    margin: 0 auto;
    padding: clamp(2rem, 5vw, 3.5rem);
    border: 1px solid rgb(253 230 138);
    border-radius: 1.75rem;
    background: rgb(255 251 235);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: rgb(180 83 9);
    font-weight: 500;
    transition: color 180ms ease;
  }

  .back-link:hover {
    color: rgb(146 64 14);
  }

  .ip-contact-link {
    display: block;
    color: rgb(180 83 9);
    font-weight: 500;
    transition: color 180ms ease;
  }

  .ip-contact-link:hover {
    color: rgb(146 64 14);
  }

  .ip-whatsapp {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.65rem;
    color: rgb(180 83 9);
    font-size: 0.9rem;
    font-weight: 500;
  }

  .ip-whatsapp img {
    width: 5.5rem;
    height: 5.5rem;
    padding: 0.25rem;
    border: 1px solid rgb(253 230 138);
    border-radius: 0.5rem;
    background: white;
  }

  :global(.dark) .detail-card {
    border-color: rgb(39 39 42);
    background: rgb(9 9 11);
  }

  :global(.dark) .ip-contact-card {
    border-color: rgb(120 53 15);
    background: rgb(69 26 3 / 28%);
  }

  :global(.dark) .ip-contact-link {
    color: rgb(251 191 36);
  }

  :global(.dark) .back-link {
    color: rgb(251 191 36);
  }

  :global(.dark) .ip-whatsapp {
    color: rgb(251 191 36);
  }
</style>
